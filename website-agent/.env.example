# Copy to .env and fill in. The backend reads these via os.getenv at startup.

# LLM provider: "gemini" | "anthropic" | "openai"
VOUCH_LLM_PROVIDER=gemini

# Required for the gemini provider
GEMINI_API_KEY=paste-your-key-here
GEMINI_MODEL=gemini-2.5-flash

# CORS — add any host you serve the website from
VOUCH_CORS_ORIGINS=http://localhost:3000,http://localhost:3100,http://localhost:3200

# Sidecar (don't change unless you moved it)
VOUCH_SIDECAR_URL=http://127.0.0.1:8877
VOUCH_AGENT_DID=did:web:agent.vouch-protocol.org
