{
  "name": "@vouch-protocol-official/api-client",
  "version": "0.1.0",
  "description": "Typed HTTP client for the Vouch Protocol Bridge API (sign, verify, audio), generated from its OpenAPI spec.",
  "author": "Ramprasad Anandam Gaddam",
  "license": "Apache-2.0",
  "homepage": "https://vouch-protocol.com",
  "keywords": [
    "vouch",
    "verifiable-credentials",
    "api-client",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vouch-protocol/vouch.git",
    "directory": "sdks/clients/typescript"
  },
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "^4.0 || ^5.0"
  }
}
