{
  "Vouch: local-first sign + verify quickstart": {
    "prefix": ["vouch-quickstart", "vouch-local"],
    "description": "In-process sign + verify with did:web:localhost; no hosting required.",
    "body": [
      "import {",
      "  Signer,",
      "  Verifier,",
      "  generateIdentity,",
      "  buildVouchCredential,",
      "} from '@vouch-protocol/core';",
      "",
      "async function main() {",
      "  const identity = await generateIdentity('${1:localhost}');",
      "",
      "  const signer = new Signer({",
      "    privateKey: identity.privateKeyJwk,",
      "    did: identity.did!,",
      "  });",
      "",
      "  const credential = buildVouchCredential({",
      "    subjectDid: identity.did!,",
      "    intent: {",
      "      action: '${2:submit_claim}',",
      "      target: '${3:claim:HC-001}',",
      "      resource: '${4:https://insurance.example.com/claims/HC-001}',",
      "    },",
      "    validSeconds: 300,",
      "  });",
      "",
      "  const signed = await signer.signCredential(credential);",
      "  console.log('signed proof value:', signed.proof.proofValue);",
      "",
      "  const verifier = new Verifier({",
      "    trustedRoots: { [identity.did!]: identity.publicKeyJwk },",
      "    allowDidResolution: false,",
      "  });",
      "  const result = await verifier.verifyCredential(signed);",
      "  console.log('valid:', result.valid, 'reasons:', result.reasons);",
      "}",
      "",
      "main().catch(console.error);$0"
    ]
  },
  "Vouch: Express verifier middleware": {
    "prefix": ["vouch-express-middleware", "vouch-middleware"],
    "description": "Drop-in Express middleware that rejects requests without a valid Vouch-Token.",
    "body": [
      "import express from 'express';",
      "import { Verifier } from '@vouch-protocol/core';",
      "",
      "const verifier = new Verifier();",
      "",
      "export const vouchMiddleware: express.RequestHandler = async (req, res, next) => {",
      "  const token = req.header('Vouch-Token');",
      "  if (!token) return res.status(401).send('Missing Vouch-Token header');",
      "  const { valid, passport } = await verifier.checkVouch(token);",
      "  if (!valid || !passport) return res.status(401).send('Invalid Vouch-Token');",
      "  (req as any).vouchPassport = passport;",
      "  next();",
      "};$0"
    ]
  }
}
