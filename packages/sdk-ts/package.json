{
 "name": "@vouch-protocol-official/sdk",
 "version": "2.0.0",
 "description": "Official TypeScript SDK for Vouch Protocol. Verifiable Credentials with Data Integrity proofs (eddsa-jcs-2022), Multikey verification methods, optional hybrid post-quantum profile (Ed25519 + ML-DSA-44), plus a daemon client for delegating signing operations.",
 "keywords": [
  "vouch",
  "vouch-protocol",
  "ai-agents",
  "agent-identity",
  "verifiable-credentials",
  "vc",
  "w3c",
  "data-integrity",
  "eddsa-jcs-2022",
  "did",
  "multikey",
  "ed25519",
  "post-quantum",
  "ml-dsa",
  "hybrid-pq",
  "signing",
  "c2pa",
  "content-credentials",
  "provenance",
  "identity",
  "cryptography"
 ],
 "author": "Ramprasad Anandam Gaddam",
 "license": "Apache-2.0",
 "repository": {
  "type": "git",
  "url": "https://github.com/vouch-protocol/vouch.git",
  "directory": "packages/sdk-ts"
 },
 "homepage": "https://vouch-protocol.com",
 "bugs": {
  "url": "https://github.com/vouch-protocol/vouch/issues"
 },
 "main": "./dist/index.js",
 "module": "./dist/index.mjs",
 "types": "./dist/index.d.ts",
 "bin": {
  "vouch-sidecar-ts": "./dist/sidecar/cli.js"
 },
 "exports": {
  ".": {
   "import": {
    "types": "./dist/index.d.mts",
    "default": "./dist/index.mjs"
   },
   "require": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
   }
  },
  "./portable": {
   "import": {
    "types": "./dist/portable.d.mts",
    "default": "./dist/portable.mjs"
   },
   "require": {
    "types": "./dist/portable.d.ts",
    "default": "./dist/portable.js"
   }
  },
  "./package.json": "./package.json"
 },
 "files": [
  "dist",
  "README.md"
 ],
 "scripts": {
  "build": "tsup src/index.ts src/portable.ts src/sidecar/cli.ts src/sidecar/server.ts --format cjs,esm --dts --clean",
  "prepublishOnly": "npm run build",
  "typecheck": "tsc --noEmit",
  "lint": "eslint src --ext .ts",
  "test": "vitest run"
 },
 "engines": {
  "node": ">=18.0.0"
 },
 "dependencies": {
  "@noble/ed25519": "^3.0.0",
  "@noble/hashes": "^1.4.0",
  "jose": "^5.2.0"
 },
 "peerDependencies": {
  "@noble/post-quantum": "^0.4.0",
  "@vouch-protocol-official/core-wasm": "^0.1.0"
 },
 "peerDependenciesMeta": {
  "@noble/post-quantum": {
   "optional": true
  },
  "@vouch-protocol-official/core-wasm": {
   "optional": true
  }
 },
 "devDependencies": {
  "@noble/post-quantum": "^0.4.0",
  "@types/node": "^20.10.0",
  "tsup": "^8.0.0",
  "typescript": "^5.3.0",
  "vitest": "^1.0.0"
 },
 "sideEffects": false
}
